{
	"name": "toknd",
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "bun run --hot src/index.ts",
		"test": "bun test",
		"lint": "bunx @biomejs/biome check src",
		"format": "bunx @biomejs/biome format --write src",
		"prepare": "husky"
	},
	"dependencies": {
		"@phosphor-icons/core": "^2.1.1",
		"hono": "^4.12.18",
		"ioredis": "^5.10.1",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@types/node": "^22.19.18",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.4",
		"typescript": "^5.9.3"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,json}": [
			"biome check --write --no-errors-on-unmatched"
		]
	}
}
